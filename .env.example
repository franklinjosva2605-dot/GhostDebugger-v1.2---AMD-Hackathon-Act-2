# GhostDebugger environment configuration
# Copy this file to .env and fill in your keys.
#
#   cp .env.example .env
#
# GhostDebugger runs with NO keys configured (it falls back to Ollama,
# then to a mock response) — but you'll get real model output once you
# add a Fireworks AI key here.

# Get a key at https://fireworks.ai (used for Qwen 1.5B / Llama 8B / Llama 70B tiers)
FIREWORKS_API_KEY=

# Optional: only needed if you run a local Ollama server for offline fallback.
# Defaults to http://localhost:11434 if not set.
OLLAMA_HOST=http://localhost:11434
